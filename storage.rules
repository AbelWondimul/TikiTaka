rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTeacher() {
      return isAuthenticated() && (
        request.auth.token.role == 'teacher' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    function isEnrolledInClass(classId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/classes/$(classId)) &&
        request.auth.uid in firestore.get(/databases/(default)/documents/classes/$(classId)).data.studentIds;
    }

    function isTAofClass(classId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/classes/$(classId)) &&
        request.auth.uid in firestore.get(/databases/(default)/documents/classes/$(classId)).data.get('taIds', []);
    }

    // Helper — allow only PDF MIME, with the broader application/octet-stream
    // permitted because some browsers/SDKs upload PDFs without a content-type.
    function isPdfUpload() {
      return request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType == null;
    }

    function isVideoUpload() {
      return request.resource.contentType == null
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType.matches('video/.*');
    }

    function isImageUpload() {
      return request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    match /raw/{uid}/{jobId} {
      // PDF student submissions — owner-only write, ≤20 MB, PDF content-type.
      allow write: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.size < 20 * 1024 * 1024
        && isPdfUpload();
      allow read: if isAuthenticated() && (request.auth.uid == uid || isTeacher());
    }
    match /results/{uid}/{jobId} {
      allow write: if false;
      allow read: if isAuthenticated() && (request.auth.uid == uid || isTeacher());
    }

    // Legacy fallback — restrict to owner or teacher
    match /raw/{jobId} {
      allow write: if false;
      allow read: if isTeacher();
    }
    match /results/{jobId} {
      allow write: if false;
      allow read: if isTeacher();
    }

    match /knowledgeBase/{classId}/{docId} {
      allow read: if isAuthenticated() && (isTeacher() || isEnrolledInClass(classId) || isTAofClass(classId));
      // Teacher reference materials — PDFs only, ≤50 MB.
      allow write: if isTeacher()
        && request.resource.size < 50 * 1024 * 1024
        && isPdfUpload();
    }

    match /moduleResources/{classId}/{docId} {
      allow read: if isAuthenticated() && (isTeacher() || isEnrolledInClass(classId) || isTAofClass(classId));
      // Module attachments — PDFs only, ≤50 MB.
      allow write: if isTeacher()
        && request.resource.size < 50 * 1024 * 1024
        && isPdfUpload();
    }

    match /assignments/{classId}/{fileId} {
      // Assignment PDFs — teacher-only, ≤50 MB.
      allow write: if isTeacher()
        && request.resource.size < 50 * 1024 * 1024
        && isPdfUpload();
      allow read: if isAuthenticated() && (
        isTeacher() || isEnrolledInClass(classId) || isTAofClass(classId)
      );
    }

    // Video submissions (DECISIONS.md #22). Owner-only write capped at 500 MB
    // to match the in-browser MediaRecorder/upload limit. Owner reads their
    // own video; teachers (admin) read any video for grading. Restrict to
    // video/* MIME so uploaders cannot stash arbitrary blobs here.
    match /videoSubmissions/{uid}/{jobId} {
      allow write: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.size < 500 * 1024 * 1024
        && isVideoUpload();
      allow read: if isAuthenticated() && (request.auth.uid == uid || isTeacher());
    }

    match /avatars/{uid} {
      // Avatar — owner-only, ≤5 MB, image/* only.
      allow write: if isAuthenticated()
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && isImageUpload();
      allow read: if isAuthenticated();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
