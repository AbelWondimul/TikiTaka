rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTeacher() {
      return isAuthenticated() && (
        request.auth.token.role == 'teacher' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }

    function isEnrolledInClass(classId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/classes/$(classId)) &&
        request.auth.uid in firestore.get(/databases/(default)/documents/classes/$(classId)).data.studentIds;
    }

    function isTAofClass(classId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/classes/$(classId)) &&
        request.auth.uid in firestore.get(/databases/(default)/documents/classes/$(classId)).data.get('taIds', []);
    }

    match /raw/{uid}/{jobId} {
      allow write: if isAuthenticated() && request.auth.uid == uid && request.resource.size < 20 * 1024 * 1024;
      allow read: if isAuthenticated() && (request.auth.uid == uid || isTeacher());
    }
    match /results/{uid}/{jobId} {
      allow write: if false;
      allow read: if isAuthenticated() && (request.auth.uid == uid || isTeacher());
    }

    // Legacy fallback — restrict to owner or teacher
    match /raw/{jobId} {
      allow write: if false;
      allow read: if isTeacher();
    }
    match /results/{jobId} {
      allow write: if false;
      allow read: if isTeacher();
    }

    match /knowledgeBase/{classId}/{docId} {
      allow read: if isAuthenticated() && (isTeacher() || isEnrolledInClass(classId) || isTAofClass(classId));
      allow write: if isTeacher();
    }

    match /moduleResources/{classId}/{docId} {
      allow read: if isAuthenticated() && (isTeacher() || isEnrolledInClass(classId) || isTAofClass(classId));
      allow write: if isTeacher();
    }

    match /assignments/{classId}/{fileId} {
      allow write: if isTeacher();
      allow read: if isAuthenticated() && (
        isTeacher() || isEnrolledInClass(classId) || isTAofClass(classId)
      );
    }

    // Video submissions (DECISIONS.md #22). Owner-only write capped at 500 MB
    // to match the in-browser MediaRecorder/upload limit. Owner reads their
    // own video; teachers (admin) read any video for grading.
    match /videoSubmissions/{uid}/{jobId} {
      allow write: if isAuthenticated() && request.auth.uid == uid && request.resource.size < 500 * 1024 * 1024;
      allow read: if isAuthenticated() && (request.auth.uid == uid || isTeacher());
    }

    match /avatars/{uid} {
      allow write: if isAuthenticated() && request.auth.uid == uid && request.resource.size < 5 * 1024 * 1024;
      allow read: if isAuthenticated();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
