NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxx

# Arbitrary secret shared with teachers at sign-up to gate teacher registration.
# Also set this in Firebase Secrets: firebase functions:secrets:set TEACHER_INVITE_TOKEN
TEACHER_INVITE_TOKEN=your-teacher-invite-token

# Your Google AI Studio API key — for local dev only.
# In production, set via: firebase functions:secrets:set GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key
