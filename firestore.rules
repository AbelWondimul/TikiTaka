rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // Helper Functions
    // ─────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTeacher() {
      return isAuthenticated() && (
        request.auth.token.role == 'teacher' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher')
      );
    }

    function isStudent() {
      return isAuthenticated() && (
        request.auth.token.role == 'student' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student')
      );
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Returns true if the calling user is enrolled in the given classId
    function isEnrolledInClass(classId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/classes/$(classId)) &&
        request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.studentIds;
    }

    // Returns true if the calling teacher owns the given classId
    function isTeacherOfClass(classId) {
      return isTeacher() &&
        exists(/databases/$(database)/documents/classes/$(classId)) &&
        request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId;
    }

    // Returns true if the calling user is a TA for the given classId
    function isTAofClass(classId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/classes/$(classId)) &&
        request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.get('taIds', []);
    }

    // ─────────────────────────────────────────
    // Users
    // ─────────────────────────────────────────

    match /users/{userId} {
      // Any authenticated user can read profiles (teachers look up their students)
      allow read: if isAuthenticated();
      // Only the user themselves can write their own profile
      allow write: if isOwner(userId);
    }

    // ─────────────────────────────────────────
    // Registration Payloads
    // Kept from Iteration 1-2 for authentication flow.
    // Only Cloud Functions read this — clients never read it.
    // ─────────────────────────────────────────

    match /registration_payloads/{userId} {
      allow write: if isOwner(userId);
      allow read: if false;
    }

    // ─────────────────────────────────────────
    // Classes
    // ─────────────────────────────────────────

    match /classes/{classId} {
      // Teacher creates their own class — teacherId must match their uid at creation
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // Teacher updates/deletes their own class freely
      // Students may modify studentIds and archivedStudents for join/leave — no other fields
      // Join: append their own uid to studentIds
      // Leave: remove themselves from studentIds and add themselves to archivedStudents
      allow update: if (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                       (isStudent() &&
                        (
                          // Join — only studentIds changes, uid appended
                          (request.resource.data.diff(resource.data).affectedKeys() == ['studentIds'].toSet() &&
                           request.resource.data.studentIds.hasAll(resource.data.studentIds) &&
                           request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1 &&
                           request.resource.data.studentIds.hasAll([request.auth.uid]))
                          ||
                          // Leave — studentIds shrinks by 1, archivedStudents grows by 1 (their uid)
                          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds', 'archivedStudents']) &&
                           resource.data.studentIds.hasAll([request.auth.uid]) &&
                           !request.resource.data.studentIds.hasAll([request.auth.uid]) &&
                           request.resource.data.studentIds.size() == resource.data.studentIds.size() - 1 &&
                           resource.data.studentIds.hasAll(request.resource.data.studentIds))
                          ||
                          // Extension request — only extensionDueDates and extensionPassesUsed change
                          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['extensionDueDates', 'extensionPassesUsed']) &&
                           resource.data.studentIds.hasAll([request.auth.uid]))
                        ));

      allow delete: if isTeacher() && resource.data.teacherId == request.auth.uid;

      // Any authenticated user can read classes so students can query by classCode to join
      allow read: if isAuthenticated();
    }

    // ─────────────────────────────────────────
    // Knowledge Base
    // ─────────────────────────────────────────

    match /knowledgeBase/{docId} {
      // Only teachers can write knowledge base documents
      allow write: if isTeacher();

      // Teachers can read all knowledge base docs
      // Students can only read docs belonging to a class they are enrolled in
      // TAs can read docs for classes they TA
      allow read: if isTeacher() ||
                     (isStudent() && isEnrolledInClass(resource.data.classId)) ||
                     (resource.data.classId is string && isTAofClass(resource.data.classId));
    }

    // ─────────────────────────────────────────
    // Grading Jobs
    // ─────────────────────────────────────────

    match /gradingJobs/{jobId} {
      // Student creates — client MUST write both studentId and teacherId on the document.
      // teacherId must be a non-empty string so teacher-scoped rules function correctly.
      allow create: if isStudent() &&
                       request.resource.data.studentId == request.auth.uid &&
                       request.resource.data.teacherId is string &&
                       request.resource.data.teacherId != '';

      // Re-grade / Appeal flow — tightly constrained per actor
      allow update: if isAuthenticated() && (
        // Student can dispute with a reason — status + appealReason + appealedAt
        (isStudent() &&
         resource.data.studentId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'appealReason', 'appealedAt']) &&
         request.resource.data.status == 'disputed' &&
         request.resource.data.appealReason is string &&
         request.resource.data.appealReason.size() <= 1000)
        ||
        // Teacher overrides grade details or responds to appeals
        (isTeacher() &&
         resource.data.teacherId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'gradedQuestions', 'score', 'appealResponse', 'appealRespondedAt']))
        ||
        // TA can edit grades (score, gradedQuestions, status) for classes they TA
        (resource.data.classId is string && resource.data.classId != '' &&
         isTAofClass(resource.data.classId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'gradedQuestions', 'score']))
      );

      // Grading jobs are audit records — no one deletes them
      allow delete: if false;

      // Student reads their own jobs; teacher reads jobs in their class; TA reads jobs in their TA class
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.studentId == request.auth.uid ||
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          (resource.data.classId is string && resource.data.classId != '' && isTeacherOfClass(resource.data.classId))
        )) ||
        (resource.data.classId is string && resource.data.classId != '' && isTAofClass(resource.data.classId))
      );
    }

    // ─────────────────────────────────────────
    // Quiz Attempts
    // ─────────────────────────────────────────

    match /quizAttempts/{attemptId} {
      // Student creates their own attempt — studentId must match their uid
      allow create: if isStudent() && request.auth.uid == request.resource.data.studentId;

      // Student reads their own attempts
      // Teacher reads all attempts for any class they own
      // TAs can read attempts for classes they TA
      // Falls back to class ownership for documents that pre-date the teacherId field
      allow read: if isAuthenticated() && (
        resource != null && (
          request.auth.uid == resource.data.studentId
          ||
          (isTeacher() && (
            request.auth.uid == resource.data.teacherId
            ||
            (resource.data.classId is string && resource.data.classId != '' && isTeacherOfClass(resource.data.classId))
          ))
          ||
          (resource.data.classId is string && resource.data.classId != '' && isTAofClass(resource.data.classId))
        )
      );

      // Immutable once created — neither students nor teachers can alter or remove attempts
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // Usage
    // ─────────────────────────────────────────

    match /usage/{docId} {
      // Only teachers can view usage metrics — written exclusively by Cloud Functions
      allow read: if isTeacher();
      allow write: if false;
    }

    // ─────────────────────────────────────────
    // Assignments (Homeworks)
    // ─────────────────────────────────────────

    match /assignments/{assignmentId} {
      // Teacher creates their own assignment
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // Teacher updates/deletes only their own assignments
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;

      // Teacher reads their own assignments.
      // Students read assignments if they are enrolled in the class.
      // TAs can read assignments for classes they TA.
      allow read: if isAuthenticated() && (
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          (resource.data.classId is string && resource.data.classId != '' && isTeacherOfClass(resource.data.classId))
        ))
        ||
        (isStudent() &&
         resource.data.classId is string &&
         resource.data.classId != '' &&
         isEnrolledInClass(resource.data.classId))
        ||
        (resource.data.classId is string && resource.data.classId != '' && isTAofClass(resource.data.classId))
      );
    }

    // ─────────────────────────────────────────
    // Quizzes
    // ─────────────────────────────────────────

    match /quizzes/{quizId} {
      // Teacher creates their own quiz — teacherId must be their uid at write time
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // Teacher updates/deletes only their own quizzes
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;

      // Teacher reads their own quizzes via direct read or collection query.
      // Inline field check (not isOwner) is required for collection queries to work —
      // isOwner() passes uid as an argument which Firestore cannot resolve at query time.
      // Students read active quizzes only if classId is valid and they are enrolled.
      allow read: if isAuthenticated() && (
        (isTeacher() && (
          resource.data.teacherId == request.auth.uid ||
          (resource.data.classId is string && resource.data.classId != '' && isTeacherOfClass(resource.data.classId))
        ))
        ||
        (isStudent() &&
         resource.data.isActive == true &&
         resource.data.classId is string &&
         resource.data.classId != '' &&
         isEnrolledInClass(resource.data.classId))
        ||
        (resource.data.classId is string && resource.data.classId != '' && isTAofClass(resource.data.classId))
      );
    }

    // ─────────────────────────────────────────
    // Conversations & Messages
    // ─────────────────────────────────────────

    match /conversations/{conversationId} {
      // Allow read if user is participant or TA of the class
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.teacherId ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );

      // Allow create if student enrolled, teacher owns class, or TA of class
      allow create: if isAuthenticated() && (
        (isStudent() && request.auth.uid == request.resource.data.studentId && isEnrolledInClass(request.resource.data.classId)) ||
        (isTeacher() && request.auth.uid == request.resource.data.teacherId && isTeacherOfClass(request.resource.data.classId)) ||
        (request.resource.data.classId is string && isTAofClass(request.resource.data.classId))
      );

      // Allow update if user is participant or TA
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.teacherId ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );

      match /messages/{messageId} {
        // Read/create messages if participant or TA
        allow read: if isAuthenticated() &&
          exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
          (
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.studentId == request.auth.uid ||
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.teacherId == request.auth.uid ||
            (get(/databases/$(database)/documents/conversations/$(conversationId)).data.classId is string &&
             isTAofClass(get(/databases/$(database)/documents/conversations/$(conversationId)).data.classId))
          );

        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 5000 &&
          exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
          (
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.studentId == request.auth.uid ||
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.teacherId == request.auth.uid ||
            (get(/databases/$(database)/documents/conversations/$(conversationId)).data.classId is string &&
             isTAofClass(get(/databases/$(database)/documents/conversations/$(conversationId)).data.classId))
          );
      }
    }

    // ─────────────────────────────────────────
    // Modules (weekly content containers)
    // ─────────────────────────────────────────

    match /modules/{moduleId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      allow read: if isAuthenticated() && (
        (isTeacher() && resource.data.teacherId == request.auth.uid) ||
        (isStudent() && resource.data.classId is string && isEnrolledInClass(resource.data.classId)) ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );
    }

    // ─────────────────────────────────────────
    // Module Resources (items within modules)
    // ─────────────────────────────────────────

    match /moduleResources/{resourceId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      allow read: if isAuthenticated() && (
        (isTeacher() && resource.data.teacherId == request.auth.uid) ||
        (isStudent() && resource.data.classId is string && isEnrolledInClass(resource.data.classId)) ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );
    }

    // ─────────────────────────────────────────
    // Module Progress (tracks student resource views)
    // ─────────────────────────────────────────

    match /moduleProgress/{progressId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        (isTeacher() && resource.data.classId is string && isTeacherOfClass(resource.data.classId)) ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // Forum Posts (anonymous student Q&A)
    // ─────────────────────────────────────────

    match /forumPosts/{postId} {
      // Students enrolled in the class can create posts with content length validation
      allow create: if isStudent() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.classId is string &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 1000 &&
        isEnrolledInClass(request.resource.data.classId);

      // Students can update upvotedBy (upvote) or replies (add reply)
      // Teachers and TAs can update (moderation + replies)
      allow update: if isAuthenticated() && (
        // Student: upvote or reply
        (isStudent() &&
         isEnrolledInClass(resource.data.classId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotedBy', 'replies']))
        ||
        // Teacher moderation + replies
        (isTeacher() && isTeacherOfClass(resource.data.classId))
        ||
        // TA can reply (only replies field)
        (isTAofClass(resource.data.classId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies']))
      );

      // Teacher can delete posts from their class
      allow delete: if isTeacher() && isTeacherOfClass(resource.data.classId);

      // Students enrolled, teachers, and TAs can read
      // IMPORTANT: authorId is in the doc but teacher/TA UI must NOT display it
      allow read: if isAuthenticated() && (
        (isStudent() && isEnrolledInClass(resource.data.classId)) ||
        (isTeacher() && isTeacherOfClass(resource.data.classId)) ||
        isTAofClass(resource.data.classId)
      );
    }

    // ─────────────────────────────────────────
    // Attendance
    // ─────────────────────────────────────────

    match /attendance/{recordId} {
      allow create, update: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        (resource.data.classId is string && isEnrolledInClass(resource.data.classId)) ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );
      allow delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // ─────────────────────────────────────────
    // Office Hours
    // ─────────────────────────────────────────

    match /officeHours/{slotId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        (resource.data.classId is string && isEnrolledInClass(resource.data.classId)) ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );
    }

    match /officeHourBookings/{bookingId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.teacherId == request.auth.uid
      );
      allow delete: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.teacherId == request.auth.uid
      );
    }

    // ─────────────────────────────────────────
    // Schedules
    // ─────────────────────────────────────────

    match /schedules/{blockId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;

      // Teachers read their own; students read if enrolled in the class; TAs read for their classes
      allow read: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        (resource.data.classId is string && isEnrolledInClass(resource.data.classId)) ||
        (resource.data.classId is string && isTAofClass(resource.data.classId))
      );
    }

    // ─────────────────────────────────────────
    // Notifications
    // ─────────────────────────────────────────

    match /notifications/{notifId} {
      // Authenticated users can create notifications with validation
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.recipientId is string;

      // Only the recipient can read or update (mark as read) their notifications
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;

      // Only the recipient can delete their notifications
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // ─────────────────────────────────────────
    // Submission Drafts (student text submission drafts)
    // ─────────────────────────────────────────

    match /submissionDrafts/{draftId} {
      // Only the student who owns the draft can read/write
      allow read, write: if isAuthenticated() && resource == null || resource.data.studentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
    }

    // ─────────────────────────────────────────
    // Backstop Deny — catches all unmatched document paths
    // ─────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
