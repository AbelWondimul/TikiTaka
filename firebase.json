{
  "hosting": {
    "public": "apps/web/out",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/student/class/:classId",
        "destination": "/student/class/[classId].html"
      },
      {
        "source": "/student/quiz/:classId",
        "destination": "/student/quiz/[classId].html"
      },
      {
        "source": "/student/submission/:jobId",
        "destination": "/student/submission/[jobId].html"
      },
      {
        "source": "/teacher/class/:classId",
        "destination": "/teacher/class/[classId].html"
      },
      {
        "source": "/teacher/class/:classId/student/:uid",
        "destination": "/teacher/class/[classId]/student/[uid].html"
      },
      {
        "source": "/teacher/class/:classId/quiz/:quizId",
        "destination": "/teacher/class/[classId]/quiz/[quizId].html"
      },
      {
        "source": "/teacher/homework/:homeworkId",
        "destination": "/teacher/homework/[homeworkId].html"
      },
      {
        "source": "/teacher/homework/:homeworkId/submissions/:submissionId",
        "destination": "/teacher/homework/[homeworkId]/submissions/[submissionId].html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions/grading",
      "codebase": "grading",
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "cd functions/grading && python -m venv venv && python -c \"import subprocess,sys,os; pip=os.path.join('venv','Scripts','pip') if os.name=='nt' else os.path.join('venv','bin','pip'); subprocess.check_call([pip,'install','-r','requirements.txt'])\""
      ],
      "runtime": "python311"
    },
    {
      "source": "functions/quiz",
      "codebase": "quiz",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "runtime": "nodejs20"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8081
    },
    "hosting": {
      "port": 5002
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}