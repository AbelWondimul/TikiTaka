{
  "hosting": {
    "public": "apps/web/out",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/student/class/:classId",
        "destination": "/student/class/[classId].html"
      },
      {
        "source": "/student/quiz/:classId",
        "destination": "/student/quiz/[classId].html"
      },
      {
        "source": "/student/submission/:jobId",
        "destination": "/student/submission/[jobId].html"
      },
      {
        "source": "/teacher/class/:classId",
        "destination": "/teacher/class/[classId].html"
      },
      {
        "source": "/teacher/class/:classId/analytics",
        "destination": "/teacher/class/[classId]/analytics.html"
      },
      {
        "source": "/teacher/class/:classId/modules",
        "destination": "/teacher/class/[classId]/modules.html"
      },
      {
        "source": "/teacher/class/:classId/attendance",
        "destination": "/teacher/class/[classId]/attendance.html"
      },
      {
        "source": "/teacher/class/:classId/office-hours",
        "destination": "/teacher/class/[classId]/office-hours.html"
      },
      {
        "source": "/teacher/class/:classId/forum",
        "destination": "/teacher/class/[classId]/forum.html"
      },
      {
        "source": "/teacher/class/:classId/gradebook",
        "destination": "/teacher/class/[classId]/gradebook.html"
      },
      {
        "source": "/student/class/:classId/modules",
        "destination": "/student/class/[classId]/modules.html"
      },
      {
        "source": "/student/class/:classId/office-hours",
        "destination": "/student/class/[classId]/office-hours.html"
      },
      {
        "source": "/student/class/:classId/forum",
        "destination": "/student/class/[classId]/forum.html"
      },
      {
        "source": "/teacher/class/:classId/student/:uid",
        "destination": "/teacher/class/[classId]/student/[uid].html"
      },
      {
        "source": "/teacher/class/:classId/quiz/:quizId",
        "destination": "/teacher/class/[classId]/quiz/[quizId].html"
      },
      {
        "source": "/teacher/homework/:homeworkId",
        "destination": "/teacher/homework/[homeworkId].html"
      },
      {
        "source": "/teacher/homework/:homeworkId/submissions/:submissionId",
        "destination": "/teacher/homework/[homeworkId]/submissions/[submissionId].html"
      },
      {
        "source": "/teacher/assignment-builder/:classId",
        "destination": "/teacher/assignment-builder/[classId].html"
      }
    ],
    "headers": [
      {
        "source": "**/_next/static/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(woff2|woff|ttf|eot)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions/grading",
      "codebase": "grading",
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "runtime": "python311"
    },
    {
      "source": "functions/quiz",
      "codebase": "quiz",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "runtime": "nodejs20"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8081
    },
    "hosting": {
      "port": 5002
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}